# ──────────────────────────────────────────────────
# Bazaar Full-Stack — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────

# Frontend port (Next.js)
PORT=3000

# Backend port (Express)
API_PORT=3001

# ── Database ────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=bazaar
DB_PORT=5432

# ── JWT ─────────────────────────────────────────────
# IMPORTANT: Change this to a long, random string before deploying!
JWT_SECRET=change-me-to-a-very-long-random-secret-string-in-production

# ── API URLs ─────────────────────────────────────────
# URL the Next.js frontend uses to reach the backend API.
# In Docker Compose: use http://localhost:3001/api (host-side access).
# For production: replace with your real backend domain.
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# URL the backend uses for CORS allow-origin.
FRONTEND_URL=http://localhost:3000
